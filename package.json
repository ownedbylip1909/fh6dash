{
  "name": "fh6dash",
  "version": "1.1.1",
  "description": "Forza Horizon 6 telemetry dashboard for macOS",
  "author": "Ownedbylip1909",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ownedbylip1909/fh6dash"
  },
  "main": "main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.nico.fh6dash",
    "productName": "FH6 Telemetry",
    "asarUnpack": [
      "data/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "publish": {
      "provider": "github",
      "owner": "Ownedbylip1909",
      "repo": "fh6dash"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*"
    ]
  }
}
